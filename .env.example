# Fintra Configuration
# Copy this file to .env and fill in your values
#
# Cara mendapatkan kredensial:
#   BOT_TOKEN       → @BotFather di Telegram → /newbot → salin token
#   GEMINI_API_KEY  → https://aistudio.google.com/apikey → Create API Key
#   SUPERADMIN_ID   → chat @userinfobot di Telegram → dapatkan ID numerik
#   SUPERADMIN_USERNAME → username Telegram Anda (tanpa @)

BOT_TOKEN=your_telegram_bot_token_here
GEMINI_API_KEY=your_gemini_api_key_here
SUPERADMIN_ID=your_telegram_user_id_here
SUPERADMIN_USERNAME=your_telegram_username_here

# Optional overrides
DB_PATH=data/fintra.db
BACKUP_DIR=data/backups
TIMEZONE=Asia/Jakarta
